{
	"schemaVersion": 1,
	"id": "${mod_id}",
	"version": "${mod_version}",
	"name": "${mod_name}",
	"description": "A library for rendering HUD elements.",
	"authors": [
		"brainage04"
	],
	"contact": {
		"homepage": "https://github.com/brainage04/HudRendererLib",
		"sources": "https://github.com/brainage04/HudRendererLib"
	},
	"license": "MIT",
	"environment": "client",
	"entrypoints": {
		"client": [
			"io.github.brainage04.hudrendererlib.HudRendererLib"
		],
		"fabric-datagen": [
			"io.github.brainage04.hudrendererlib.datagen.DataGenerator"
		],
		"modmenu": [
			"io.github.brainage04.hudrendererlib.modmenu.ModMenuIntegration"
		]
	},
	"depends": {
		"fabricloader": ">=${loader_version}",
		"minecraft": "~${minecraft_version}",
		"java": ">=${java_version}",
		"fabric-api": "*",
		"cloth-config": ">=26.1.154"
	},
	"suggests": {
		"modmenu": "*"
	},
	"custom": {
		"modmenu": {
			"badges": [
				"library"
			]
		}
	}
}
